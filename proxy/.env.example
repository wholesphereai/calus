# --- Calus proxy config (copy to .env, never commit real secrets) ---
# Optional: leave CALUS_ADMIN_TOKEN blank and the proxy generates one and prints
# it at startup. Set it only to keep the same token across restarts.
CALUS_ADMIN_TOKEN=
CALUS_CORS_ORIGINS=http://localhost:5173
CALUS_DB_PATH=calus_proxy.db
CALUS_REDACT_STORE=1          # redact secrets/PII before storing (recommended)
CALUS_STORE_TEXT=1            # store redacted prompt/response preview
CALUS_SCAN_RESPONSES=1
CALUS_FLAG_THRESHOLD=0.5      # 0.0-1.0; confidence at/above which a call is "flagged"
CALUS_MAX_BODY_BYTES=2000000  # reject request bodies larger than this (HTTP 413)
CALUS_UPSTREAM_TIMEOUT_S=60   # upstream LLM call timeout (HTTP 504 on timeout)

# OPTIONAL data-plane token. If set, /v1/* requires it via the
# X-Calus-Proxy-Token header (or Authorization: Bearer ...), constant-time checked.
# If LEFT BLANK the proxy stays drop-in but the data plane is UNAUTHENTICATED —
# in that case do NOT expose the port publicly (bind to localhost / private net).
CALUS_PROXY_TOKEN=

# Master secret for the encrypted key vault. STRONGLY recommended in production:
# if unset, the proxy generates and persists a random secret next to the admin
# token (.calus_vault_secret). Set this explicitly so the vault stays decryptable
# if that file is lost / across deployments.
# CALUS_SECRET=

# --- upstream provider keys (read by LiteLLM, NEVER stored/logged) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
